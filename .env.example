# Decampify — environment variables (Vercel Project Settings → Environment Variables)
# Copy to .env for local `vercel dev`. NEVER commit the real .env.
# With these UNSET, the site still runs in mock mode (config.js mock:true) — no store, demo audio.

# --- Stripe (test keys are fine for building) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx          # optional, if you add a webhook later
SITE_URL=http://localhost:3000           # used to build Stripe success/cancel URLs

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
R2_BUCKET=my-artist-store
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# --- App secret for signing free-download + streaming tokens ---
MR_TOKEN_SECRET=change-me-to-a-long-random-string
