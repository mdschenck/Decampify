{
  "name": "decampify-template",
  "version": "1.0.0",
  "private": true,
  "description": "Decampify — a self-hosted artist site + digital music store template (static frontend, Vercel serverless Stripe checkout, Cloudflare R2 audio delivery, JSON-driven content, mock mode for instant demo).",
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "start": "vercel dev",
    "test": "node --test",
    "manifest": "node scripts/generate-manifest.mjs",
    "manifest:check": "node scripts/check-staging.mjs",
    "upload:check": "node --env-file=.env --env-file-if-exists=.env.upload scripts/upload-to-r2.mjs",
    "upload": "node --env-file=.env --env-file-if-exists=.env.upload scripts/upload-to-r2.mjs --go"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "@aws-sdk/lib-storage": "^3.1090.0"
  }
}
